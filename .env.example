# 沉浸式翻译 Pro 凭证(从浏览器抓包获得,重新登录后会失效需替换)
# 抓包位置:打开扩展 AI Write,F12 -> Network -> 找 /qwen/translate/stream 请求
IMMERSIVE_TOKEN=你的Token请求头
IMMERSIVE_COOKIE=完整的Cookie字符串

# 沉浸式翻译扩展 ID(一般无需改)
EXTENSION_ID=bpoadfkcbjbfhfodiogcnhhhpibjhbnh

# 上游基址与端点路径(一般无需改)
# OPENAI_PATH 是通用 OpenAI 网关(qwen/deepseek/glm/gpt/grok/plamo 都走它)
# GEMINI_PATH 是 Gemini 专用端点(响应原生格式,代理会翻译成 OpenAI)
API_BASE=https://api2.immersivetranslate.com
OPENAI_PATH=/qwen/translate/stream
GEMINI_PATH=/gemini/translate/stream
CLAUDE_PATH=/claude/translate/stream

# X-Imt-Product-Line:ai_writing / web_page 等,默认 ai_writing
X_IMT_PRODUCT_LINE=ai_writing

# 中转层 API Key:留空不鉴权;填了之后客户端需用 Bearer 该值
PROXY_API_KEY=

# 监听地址
HOST=127.0.0.1
PORT=8000

# 同时发往上游的最大并发数(防风控)
MAX_CONCURRENCY=2

# 上游超时(秒)
UPSTREAM_TIMEOUT=120

# 日志级别
LOG_LEVEL=INFO

# /v1/models 暴露的模型清单(逗号分隔,已探测确认可用)
SUPPORTED_MODELS=qwen3.5-plus,DeepSeek-V4-Flash,gpt-5-mini,glm-4.7,grok-4-3,plamo-2.2-prime,gemini-3-flash-preview,claude-haiku-4.5-20251001
